class Node:
    def __init__(self):
        self.links = [None,None]
    def containsKey(self,bit):
        if self.links[bit] is not None:
            return True
        return False
    def put(self,bit,node):
        self.links[bit] = node
    def get(self,bit):
        return self.links[bit]
class Trie:
    def __init__(self):
        self.root = Node()
    def insert(self,num):
        node = self.root
        for i in range(31,-1,-1):
            bit = (num >> i)& 1 # To extract the bit
            if node.containsKey(bit) == False:
                node.put(bit,Node())
            node = node.get(bit)
    def getMax(self,num):
        node = self.root
        maxNum = 0
        for i in range(31,-1,-1):
            bit = (num>>i)&1
            if node.containsKey(1-bit):
                maxNum = maxNum| (1<<i)
                node = node.get(1-bit)
            else:
                node = node.get(bit)
        return maxNum
class Solution:
    def findMaximumXOR(self, nums: List[int]) -> int:
        trie = Trie()
        for num in nums:
            trie.insert(num)
        maxi = 0
        for num in nums:
            maxi = max(maxi,trie.getMax(num))
        return maxi
