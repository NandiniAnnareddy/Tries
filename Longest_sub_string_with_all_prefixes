class Node:
    def __init__(self):
        self.links = [None]*26
        self.flag = False
    def containsKey(self,ch):
        if self.links[ord(ch)-ord('a')] != None:
            return True
        return False
    def put(self,ch,node):
        self.links[ord(ch)-ord('a')] = node
    def get(self,ch):
        return self.links[ord(ch)-ord('a')]
class Trie:
    def __init__(self):
        self.root = Node()
    def insert(self,word):
        node = self.root
        for ch in word:
            if node.containsKey(ch) == False:
                node.put(ch,Node())
            node = node.get(ch)
        node.flag = True
    def longest(self,words,longest):
        for word in words:
            node = self.root
            valid = True
            for ch in word:
                node = node.get(ch)
                if node.flag == False:
                    valid = False
                    break
            if valid == True:
                if (len(longest) < len(word)) or \
                   (len(word) == len(longest) and word < longest):
                    longest = word
        return longest
class Solution:
    def longestValidWord(self, words):
        longest = ""
        trie = Trie()
        for word in words:
            trie.insert(word)
        return trie.longest(words,longest)
            
                    
            
